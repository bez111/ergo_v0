  {
    "key": "minersPage.faq.questions.0.question",
    "value": "What hardware do I need to mine ERG?",
    "context": "FAQ content",
    "maxLength": 54
  },
  {
    "key": "minersPage.faq.questions.0.answer",
    "value": "Any modern GPU with 4GB+ VRAM can mine ERG efficiently. AMD and NVIDIA cards both work well. Popular choices include RTX 3070, RTX 4070, and RX 6800.",
    "context": "FAQ content",
    "maxLength": 223.5
  },
  {
    "key": "minersPage.faq.questions.1.question",
    "value": "Which mining software should I use?",
    "context": "FAQ content",
    "maxLength": 52.5
  },
  {
    "key": "minersPage.faq.questions.1.answer",
    "value": "lolMiner and T-Rex are the most popular options for ERG mining. Both are free (with dev fee) and support Windows and Linux.",
    "context": "FAQ content",
    "maxLength": 184.5
  },
  {
    "key": "minersPage.faq.questions.2.question",
    "value": "What is the current block reward?",
    "context": "FAQ content",
    "maxLength": 49.5
  },
  {
    "key": "minersPage.faq.questions.2.answer",
    "value": "The current block reward is dynamically adjusted. Check the network stats above for the latest reward amount.",
    "context": "FAQ content",
    "maxLength": 163.5
  },
  {
    "key": "minersPage.faq.questions.3.question",
    "value": "Is solo mining profitable?",
    "context": "FAQ content",
    "maxLength": 39
  },
  {
    "key": "minersPage.faq.questions.3.answer",
    "value": "For most miners, pool mining is more consistent. Solo mining requires significant hashrate to find blocks regularly.",
    "context": "FAQ content",
    "maxLength": 174
  }
