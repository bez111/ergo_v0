  {
    "key": "privacyFeatures.faq.items.0.question",
    "value": "How does Ergo implement privacy?",
    "context": "FAQ content",
    "maxLength": 48
  },
  {
    "key": "privacyFeatures.faq.items.0.answer",
    "value": "Ergo uses Sigma protocols for zero-knowledge proofs, enabling optional privacy features like ErgoMixer, ring signatures, and confidential transactions without trusted setup.",
    "context": "FAQ content",
    "maxLength": 259.5
  },
  {
    "key": "privacyFeatures.faq.items.1.question",
    "value": "Is Ergo a privacy coin?",
    "context": "FAQ content",
    "maxLength": 34.5
  },
  {
    "key": "privacyFeatures.faq.items.1.answer",
    "value": "Ergo offers optional privacy. Users can choose transparent or confidential transactions. Privacy is a feature, not mandatory, maintaining regulatory compliance.",
    "context": "FAQ content",
    "maxLength": 240
  },
  {
    "key": "privacyFeatures.faq.items.2.question",
    "value": "What is ErgoMixer?",
    "context": "FAQ content",
    "maxLength": 27
  },
  {
    "key": "privacyFeatures.faq.items.2.answer",
    "value": "ErgoMixer is a non-custodial, trustless mixing protocol that breaks transaction links using Sigma protocols, providing strong privacy without centralized operators.",
    "context": "FAQ content",
    "maxLength": 246
  },
  {
    "key": "privacyFeatures.faq.items.3.question",
    "value": "Are privacy features secure?",
    "context": "FAQ content",
    "maxLength": 42
  },
  {
    "key": "privacyFeatures.faq.items.3.answer",
    "value": "Yes, Ergo's privacy features are based on proven cryptographic protocols with mathematical security guarantees. No trusted setup is required.",
    "context": "FAQ content",
    "maxLength": 211.5
