  {
    "key": "learnErgoscript.faqs.needPriorExperience.question",
    "value": "Do I need prior blockchain experience to start?",
    "context": "FAQ content",
    "maxLength": 70.5
  },
  {
    "key": "learnErgoscript.faqs.needPriorExperience.answer",
    "value": "No! Our tutorial series starts from the basics and gradually builds up complexity. We explain blockchain and smart contract concepts as we go, making it accessible for complete beginners.",
    "context": "FAQ content",
    "maxLength": 280.5
  },
  {
    "key": "learnErgoscript.faqs.ergoScriptDifferentFromSolidity.question",
    "value": "How is ErgoScript different from Solidity?",
    "context": "FAQ content",
    "maxLength": 63
  },
  {
    "key": "learnErgoscript.faqs.ergoScriptDifferentFromSolidity.answer",
    "value": "ErgoScript is based on Scala and designed for the eUTXO model, offering better security guarantees, predictable costs, and native support for advanced cryptography like Sigma protocols. It's more functional and mathematically rigorous than Solidity.",
    "context": "FAQ content",
    "maxLength": 373.5
  },
  {
    "key": "learnErgoscript.faqs.developmentTools.question",
    "value": "What development tools do I need?",
    "context": "FAQ content",
    "maxLength": 49.5
  },
  {
    "key": "learnErgoscript.faqs.developmentTools.answer",
    "value": "You'll need a text editor, the Ergo node software, and optionally the ErgoScript compiler. We provide detailed setup instructions in Module 1.3 to get you started with the complete development environment.",
    "context": "FAQ content",
    "maxLength": 307.5
  },
  {
