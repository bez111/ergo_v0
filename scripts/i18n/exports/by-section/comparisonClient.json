  {
    "key": "comparisonClient.faq.questions.0.q",
    "value": "How does eUTXO reduce reentrancy risk?",
    "context": "FAQ content",
    "maxLength": 57
  },
  {
    "key": "comparisonClient.faq.questions.0.a",
    "value": "Transactions consume specified UTXOs and cannot be re-entered; the shared-state pattern behind reentrancy is absent.",
    "context": "FAQ content",
    "maxLength": 174
  },
  {
    "key": "comparisonClient.faq.questions.1.q",
    "value": "Are fees predictable on Ergo?",
    "context": "FAQ content",
    "maxLength": 43.5
  },
  {
    "key": "comparisonClient.faq.questions.1.a",
    "value": "Script cost is bounded and fees are predictable; there are no gas price auctions (final fees depend on mempool conditions).",
    "context": "FAQ content",
    "maxLength": 184.5
  },
  {
    "key": "comparisonClient.faq.questions.2.q",
    "value": "Does Ergo have light clients?",
    "context": "FAQ content",
    "maxLength": 43.5
  },
  {
    "key": "comparisonClient.faq.questions.2.a",
    "value": "Yes. NIPoPoWs enable succinct proofs for trust-minimized light clients.",
    "context": "FAQ content",
