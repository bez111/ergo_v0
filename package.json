{
  "name": "ergo-blockchain",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "analyze": "ANALYZE=true next build",
    "type-check": "tsc --noEmit",
    "lint:fix": "next lint --fix",
    "clean": "rm -rf .next node_modules package-lock.json && npm install",
    "audit:deps": "npx depcheck",
    "audit:bundle": "npx @next/bundle-analyzer",
    "lighthouse": "lhci autorun",
    "lighthouse:mobile": "lhci autorun --collect.settings.preset=mobile",
    "lighthouse:desktop": "lhci autorun --collect.settings.preset=desktop",
    "perf:test": "npm run build && npm run lighthouse",
    "perf:analyze": "ANALYZE=true next build",
    "build:search": "node scripts/build-search-index.js",
    "search:index": "npm run build:search && echo 'Search index built successfully'",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "health": "node scripts/health-check.js",
    "health:prod": "BASE_URL=https://ergoblockchain.org node scripts/health-check.js"
  },
  "dependencies": {
    "@algolia/autocomplete-plugin-algolia-insights": "^1.19.2",
    "@algolia/autocomplete-plugin-query-suggestions": "^1.19.2",
    "@emotion/is-prop-valid": "^1.2.2",
    "@next/bundle-analyzer": "^15.3.3",
    "@next/mdx": "^15.4.4",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-collapsible": "^1.0.3",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.8",
    "gray-matter": "^4.0.3",
    "katex": "^0.16.22",
    "lucide-react": "^0.454.0",
    "next": "^15.4.1",
    "next-mdx-remote": "^5.0.0",
    "next-themes": "^0.4.6",
    "prom-client": "^15.1.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-katex": "^3.1.0",
    "react-scroll": "^1.9.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-math": "^6.0.0",
    "schema-dts": "^1.1.5",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "tinacms": "^2.8.2",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-katex": "^3.0.4",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "autoprefixer": "^10.0.1",
    "critters": "^0.0.23",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.0.4",
    "eslint-plugin-unused-imports": "^4.1.4",
    "@playwright/test": "^1.40.1",
    "axe-playwright": "^2.0.1",
    "postcss": "^8.5",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
