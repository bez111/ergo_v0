      {
        title: {
          en: "API (Application Programming Interface)",
          zh: "API（应用程序编程接口）",
          ru: "API (Интерфейс программирования приложений)",
          ko: "API (응용 프로그래밍 인터페이스)",
          ja: "API（アプリケーションプログラミングインターフェース）",
          tr: "API (Uygulama Programlama Arayüzü)",
